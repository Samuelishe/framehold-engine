DJANGO_SECRET_KEY=django-insecure-change-me-for-local-development
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
FRAMEHOLD_PUBLIC_ORIGIN=http://localhost:8000

POSTGRES_DB=framehold
POSTGRES_USER=framehold
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://framehold:password@127.0.0.1:5432/framehold

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Framehold Engine <noreply@example.test>
